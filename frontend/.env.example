# Frontend env vars. Copy to `.env` for local dev, or set them in CI for
# Firebase Hosting production builds.

# ─── Firebase Hosting (recommended for production) ──────────────────────────
# No env var needed. `firebase.json` declares a `rewrites.run` rule that
# proxies /api/** to the Cloud Run backend server-side. The browser sees a
# single origin — no CORS, no preflight, no cross-site cookie issues. Leave
# VITE_API_URL unset and the frontend will call the relative `/api/*` path.

# ─── Direct browser → Cloud Run (optional) ──────────────────────────────────
# Set this only if you want the browser to call Cloud Run directly, bypassing
# Firebase Hosting's rewrite. Requires CORS_ORIGINS on the backend to include
# the Firebase domain.
# VITE_API_URL=https://vc-agent-backend-abc123-uc.a.run.app

# ─── Local dev (proxy through Vite) ─────────────────────────────────────────
# Only used by `npm run dev` / `npm run preview`. Production builds ignore it.
# VITE_PROXY_TARGET=http://127.0.0.1:8000
