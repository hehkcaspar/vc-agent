# Optional: talk to FastAPI directly (CORS must allow the frontend origin; backend allows * in dev).
# Use this if Vite's /api proxy hits the wrong service (e.g. Kong on :8000 returns "no Route matched").
# VITE_API_URL=http://127.0.0.1:8000

# Optional: where Vite should proxy /api (default http://127.0.0.1:8000). Set if Uvicorn listens elsewhere.
# VITE_PROXY_TARGET=http://127.0.0.1:8001
