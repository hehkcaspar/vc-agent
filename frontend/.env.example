# Frontend env vars. Copy to `.env` for local dev, or set them in the Vercel
# project "Environment Variables" UI for deployed builds.

# ─── Remote backend (recommended for production) ────────────────────────────
# Point the browser directly at the deployed FastAPI backend. When this is an
# absolute URL, the frontend bypasses the Vite dev proxy and calls the remote
# host directly. Backend CORS_ORIGINS must include the frontend origin.
# VITE_API_URL=https://vc-agent-backend.fly.dev

# ─── Local dev (proxy through Vite) ─────────────────────────────────────────
# If VITE_API_URL is unset (or non-absolute), `/api/*` calls are proxied by
# the Vite dev server to VITE_PROXY_TARGET. Only used by `npm run dev` /
# `npm run preview` — production builds ignore this.
# Set this if Uvicorn listens on a non-default port, or if :8000 is a gateway
# (Kong etc.) that returns "no Route matched".
# VITE_PROXY_TARGET=http://127.0.0.1:8000
