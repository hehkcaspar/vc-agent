# Copy to `.env` in this directory (`backend/`) and fill in values.
# Uvicorn is typically started from `backend/`, so paths are relative to the repo root unless overridden.

# --- Storage & database ---
# DATA_ROOT=D:\path\to\data\entities
# DATABASE_URL=sqlite+aiosqlite:///D:/path/to/vc_portfolio.db

# --- Legacy chat + presets (google-genai SDK) ---
# GEMINI_API_KEY=
# Same key; code accepts either name:
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-3.1-pro-preview
# GEMINI_METADATA_EXTRACTION_MODEL=gemini-3.1-flash-lite-preview

# CHAT_MAX_HISTORY_MESSAGES=40
# CHAT_MAX_ATTACHMENT_BYTES=20971520
# CHAT_MAX_ARTIFACT_CHARS=120000
# CHAT_ENABLE_GOOGLE_SEARCH=true

# --- Deep Agent harness (LangChain Deep Agents + LangGraph) ---
# When true, POST /entities/{id}/chat/sessions/{sid}/messages uses the harness instead of one-shot google-genai.
# CHAT_USE_DEEP_AGENT=false
# CHAT_AGENT_RECURSION_LIMIT=50
# Default profile when the client omits `model_profile_id`: gemini_google | kimi_moonshot
# CHAT_DEFAULT_MODEL_PROFILE=gemini_google

# --- Harness artifact edits (Option B) ---
# CHAT_ARTIFACT_DEFAULT_EDIT_MODE=versioned
# CHAT_ARTIFACT_OVERWRITE_ENABLED=false
# CHAT_ARTIFACT_RESOLVE_MIN_SCORE=0.65

# --- Kimi / Moonshot (OpenAI-compatible /v1; LangChain ChatOpenAI) ---
# Routing: MOONSHOT_API_KEY uses MOONSHOT_BASE_URL (Open Platform). If only KIMI_CODE_API_KEY
# is set, base is KIMI_CODE_BASE_URL (Kimi Code). You may omit MOONSHOT_BASE_URL and MOONSHOT_MODEL
# in that case (defaults in config still apply for code path via KIMI_CODE_*).
# Wrong host for your key type causes 401 Invalid Authentication.
# MOONSHOT_API_KEY=
# KIMI_CODE_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
# Mainland Open Platform: https://api.moonshot.cn/v1
# KIMI_OPENAI_BASE_URL=
# MOONSHOT_MODEL=kimi-k2.5
# KIMI_CODE_MODEL=kimi-k2.5
# KIMI_CODE_HTTP_USER_AGENT=KimiCLI/1.6
# KIMI_DISABLE_THINKING_FOR_SEARCH=true

# --- Optional: LangSmith / LangChain tracing ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=vc-portfolio-agent
