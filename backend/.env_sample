# Copy to `.env` in this directory (`backend/`) and fill in values.
# Uvicorn is typically started from `backend/`, so paths are relative to the repo root unless overridden.

# --- Storage & database ---
# DATA_ROOT=D:\path\to\data\entities
# DATABASE_URL=sqlite+aiosqlite:///D:/path/to/vc_portfolio.db

# --- CORS (production) ---
# Comma-separated origins. "*" (default) is fine for local dev; in production
# set the deployed frontend URL(s). Credentials auto-enabled for concrete lists.
# CORS_ORIGINS=https://vc-agent.web.app,https://vc-agent.firebaseapp.com

# --- Cloud Run + Cloud SQL Postgres (production) ---
# Both DBs live on the same Cloud SQL Postgres instance as two separate
# databases. Connect via the unix socket that Cloud Run mounts when the
# deploy uses `--add-cloudsql-instances=PROJECT:REGION:INSTANCE`.
# Store these values in Secret Manager and pass via `--update-secrets=...`.
# DATABASE_URL=postgresql+asyncpg://vc:PASSWORD@/vc_portfolio?host=/cloudsql/PROJECT:REGION:INSTANCE
# ACADEMIC_DATABASE_URL=postgresql+asyncpg://vc:PASSWORD@/academic?host=/cloudsql/PROJECT:REGION:INSTANCE
#
# Blob + config storage via GCS FUSE mount at /mnt/gcs (the Dockerfile sets
# these defaults; override only if using a different mount path).
# DATA_ROOT=/mnt/gcs/entities
# ACADEMIC_SCHOLARS_DIR=/mnt/gcs/scholars
# ACADEMIC_CONFIG_DIR=/mnt/gcs/config
# FUNDS_CONFIG_PATH=/mnt/gcs/config/funds.json
# LEGAL_TEMPLATES_CONFIG_PATH=/mnt/gcs/config/legal_templates.json
# LEGAL_REVIEW_CHECKLIST_CONFIG_PATH=/mnt/gcs/config/legal_review_checklist.json

# --- Gemini (google-genai SDK) ---
# GEMINI_API_KEY=
# Same key; code accepts either name:
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-3.1-pro-preview
# GEMINI_METADATA_EXTRACTION_MODEL=gemini-3.1-flash-lite-preview

# CHAT_MAX_HISTORY_MESSAGES=40
# CHAT_MAX_ATTACHMENT_BYTES=20971520
# CHAT_ENABLE_GOOGLE_SEARCH=true

# --- Workspace ---
# WORKSPACE_MAX_FILE_BYTES=52428800          # 50 MB per file
# WORKSPACE_MAX_ZIP_BYTES=524288000          # 500 MB per zip upload
# WORKSPACE_VERSION_RETENTION_DAYS=30
# WORKSPACE_INTAKE_SAMPLE_SIZE=5             # Path B folder sampling budget

# --- Deep Agent harness (LangChain Deep Agents + LangGraph) ---
# When true, POST /entities/{id}/chat/sessions/{sid}/messages uses the harness instead of direct google-genai / Kimi.
# CHAT_USE_DEEP_AGENT=false
# CHAT_AGENT_RECURSION_LIMIT=50
# Default profile when the client omits `model_profile_id`: gemini_google | kimi_moonshot
# CHAT_DEFAULT_MODEL_PROFILE=gemini_google
# Gemini Interactions API TTL in days (paid tier retains 55 days; 0 = free tier / disabled)
# GEMINI_INTERACTION_TTL_DAYS=50

# --- Kimi / Moonshot (OpenAI-compatible /v1; LangChain ChatOpenAI) ---
# Routing: MOONSHOT_API_KEY uses MOONSHOT_BASE_URL (Open Platform). If only KIMI_CODE_API_KEY
# is set, base is KIMI_CODE_BASE_URL (Kimi Code). You may omit MOONSHOT_BASE_URL and MOONSHOT_MODEL
# in that case (defaults in config still apply for code path via KIMI_CODE_*).
# Wrong host for your key type causes 401 Invalid Authentication.
# MOONSHOT_API_KEY=
# KIMI_CODE_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
# Mainland Open Platform: https://api.moonshot.cn/v1
# KIMI_OPENAI_BASE_URL=
# MOONSHOT_MODEL=kimi-k2.5
# KIMI_CODE_MODEL=kimi-k2.5
# KIMI_CODE_HTTP_USER_AGENT=KimiCLI/1.6
# KIMI_DISABLE_THINKING_FOR_SEARCH=true

# --- Academic Tracking (separate DB from portfolio) ---
# ACADEMIC_DATABASE_URL=sqlite+aiosqlite:///D:/path/to/academic.db
# Uses GEMINI_API_KEY (shared with portfolio chat) for identity extraction and report generation.
# Semantic Scholar free tier works without a key (100 req/5min); optional key for higher limits.
# SEMANTIC_SCHOLAR_API_KEY=
# Gemini model for academic pipeline (identity extraction, SS author resolution, report gen).
# ACADEMIC_GEMINI_MODEL=gemini-2.5-flash
# SerpAPI key (optional, for future Google Scholar paper fetching).
# SERPAPI_KEY=

# --- Optional: pytest real LLM e2e (tests/test_chat_e2e_llm.py) ---
# Uses temp DB + DATA_ROOT; does not touch your portfolio DB.
# RUN_E2E_LLM=1

# --- Optional: LangSmith / LangChain tracing ---
# Preferred (modern):
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=vc-portfolio-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
